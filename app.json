{
  "expo": {
    "name": "nongyu",
    "slug": "nongyu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nongyu.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.nongyu.app"
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      "expo-native-wechat",
      [
        "expo-media-library",
        {
          "photosPermission": "允许农屿访问您的相册以保存分享海报",
          "savePhotosPermission": "允许农屿保存图片到您的相册",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "scheme": "wx174b5a4d92447b73",
    "extra": {
      "eas": {
        "projectId": "97b4c9d0-02d9-49d8-a658-17be8fc6851f"
      }
    }
  }
}
